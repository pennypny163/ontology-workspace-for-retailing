# 本地开发环境变量示例

# 优先使用 DATABASE_URL，如果配置了就会覆盖下面的单项变量
# DATABASE_URL="mysql+pymysql://root:password@127.0.0.1:3306/ontology?charset=utf8mb4"

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ontology
MYSQL_USER=root
MYSQL_PASSWORD=

# 语言模型配置（可选）
LLM_API_KEY=
LLM_API_BASE=https://api.example.com/v1
LLM_MODEL=gpt-4o
